{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "command -v bun >/dev/null 2>&1 && bun \"${CLAUDE_PLUGIN_ROOT}/hooks/cognition-pretooluse.ts\" || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v bun >/dev/null 2>&1 && bash \"${CLAUDE_PLUGIN_ROOT}/scripts/ensure-deps.sh\" \"${CLAUDE_PLUGIN_ROOT}\" >/dev/null 2>&1; true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v bun >/dev/null 2>&1 && bun \"${CLAUDE_PLUGIN_ROOT}/hooks/expression-sessionstart.ts\" || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v bun >/dev/null 2>&1 && bun \"${CLAUDE_PLUGIN_ROOT}/hooks/cognition-sessionstart.ts\" || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v bun >/dev/null 2>&1 && bun \"${CLAUDE_PLUGIN_ROOT}/hooks/expression-userpromptsubmit.ts\" || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v bun >/dev/null 2>&1 && bun \"${CLAUDE_PLUGIN_ROOT}/hooks/memory-recall-userpromptsubmit.ts\" || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v bun >/dev/null 2>&1 && bun \"${CLAUDE_PLUGIN_ROOT}/hooks/cognition-userpromptsubmit.ts\" || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Read|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "command -v bun >/dev/null 2>&1 && bun \"${CLAUDE_PLUGIN_ROOT}/hooks/perception-posttooluse.ts\" || true"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v bun >/dev/null 2>&1 && bun \"${CLAUDE_PLUGIN_ROOT}/hooks/memory-consolidate-sessionend.ts\" || true"
          }
        ]
      }
    ]
  }
}
